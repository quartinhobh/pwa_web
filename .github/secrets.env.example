# GitHub Actions Secrets — copie, preencha, e sete via CLI:
#   cp .github/secrets.env.example .github/secrets.env
#   # edite secrets.env com valores reais
#   gh secret set -f .github/secrets.env
#
# NÃO commite o arquivo preenchido! Só o .example vai pro repo.

RENDER_DEPLOY_HOOK=PREENCHER
FIREBASE_PROJECT_ID=PREENCHER
FIREBASE_TOKEN=PREENCHER_COM_OUTPUT_DE_bunx_firebase-tools_login:ci
VITE_API_URL=PREENCHER_URL_DO_RENDER
VITE_FIREBASE_CONFIG=PREENCHER_JSON_CONFIG_FIREBASE
