# Template for dev seed credentials.
# Copy to .env.seed (gitignored) and fill in before running `bun run seed`.
#
# WARNING: the seed script refuses to run without FIRESTORE_EMULATOR_HOST set,
# and it refuses short passwords. These values only populate the local emulator.

SEED_ADMIN_EMAIL=you@example.com
SEED_ADMIN_PASSWORD=replace-with-strong-passphrase
SEED_ADMIN_NAME=Quartinho Admin
