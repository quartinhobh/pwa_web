# Template for Firebase Hosting / production build.
# Do NOT commit the filled-in version. Copy to `.env.production` (gitignored)
# or set these as GitHub Actions secrets (see docs/deployment.md).

# Full Firebase web SDK config as JSON (apiKey, authDomain, projectId, ...).
# Get from: Firebase Console → Project Settings → General → Your apps → Config
VITE_FIREBASE_CONFIG={"apiKey":"...","authDomain":"...","projectId":"...","storageBucket":"...","messagingSenderId":"...","appId":"...","databaseURL":"..."}

# Deployed API base URL (Koyeb service URL).
VITE_API_URL=https://your-api.koyeb.app

# Leave empty or unset in production. Only set for local dev against the
# Firebase emulator suite.
# VITE_USE_EMULATOR=true
