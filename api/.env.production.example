# Template for Koyeb (or any hosted) deployment of the API.
# Do NOT commit the filled-in version. Configure these as Koyeb service
# env vars or GitHub Actions secrets (see docs/deployment.md).

NODE_ENV=production
PORT=3001

# ── Firebase Admin SDK credentials ────────────────────────────────────
# Recommended: paste the three fields extracted from the downloaded service
# account JSON. Keep the literal \n sequences in the private key — the
# runtime (api/src/config/firebase.ts) replaces them with real newlines.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Required for the Realtime Database (chat) integration.
FIREBASE_DATABASE_URL=https://<project>-default-rtdb.firebaseio.com

# Cloudflare R2 (photo uploads) — free tier, S3-compatible
# Get credentials from Cloudflare Dashboard → R2 → Manage API Tokens
# Create "S3 Token" with Object Read/Write permissions
R2_ACCOUNT_ID=<r2-account-id>
R2_ACCESS_KEY_ID=<s3-access-key-id>
R2_SECRET_ACCESS_KEY=<s3-secret-access-key>
R2_BUCKET=qbh

# Bootstrap: first user with this email automatically receives admin role
# on /auth/link. Set once during first deployment, then remove.
INITIAL_ADMIN_EMAIL=

# External APIs
MUSICBRAINZ_USER_AGENT=Quartinho/1.0 (contact@yourdomain.com)
GENIUS_ACCESS_TOKEN=

# Explicitly unset emulator hosts in production so the admin SDK uses real
# credentials. Empty values would still trigger the emulator code path —
# omit these vars entirely from the prod environment.
# FIRESTORE_EMULATOR_HOST=
# FIREBASE_AUTH_EMULATOR_HOST=
# FIREBASE_DATABASE_EMULATOR_HOST=
# FIREBASE_STORAGE_EMULATOR_HOST=
